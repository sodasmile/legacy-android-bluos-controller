<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BluOS Remote — Settings"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Player IP Address"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/edit_host"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 192.168.1.100"
        android:inputType="textNoSuggestions"
        android:textColor="#FFFFFF"
        android:textColorHint="#444444"
        android:background="#1C1C1C"
        android:padding="14dp"
        android:textSize="20sp"
        android:layout_marginBottom="10dp" />

    <!-- Auto-discover players on the local network via mDNS -->
    <Button
        android:id="@+id/btn_discover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DISCOVER PLAYERS"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="#1E5C1E"
        android:padding="12dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Port  (default: 11000)"
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/edit_port"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="11000"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textColorHint="#444444"
        android:background="#1C1C1C"
        android:padding="14dp"
        android:textSize="20sp"
        android:layout_marginBottom="36dp" />

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SAVE"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#1A73E8"
        android:padding="16dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BACK"
        android:textSize="16sp"
        android:textColor="#888888"
        android:background="#1C1C1C"
        android:padding="14dp" />

</LinearLayout>
